PORT=5050
JWT_SECRET=change-this-to-a-long-random-string
# Optional: persistent users (signup/login). Local: mongodb://127.0.0.1:27017/resume_analyzer
# Atlas: mongodb+srv://USER:PASS@cluster.mongodb.net/resume_analyzer
MONGODB_URI=
# AI chat + analysis (OpenAI-compatible /chat/completions). Same variable name works for NVIDIA or OpenAI keys.
AI_API_KEY=
# Default base is NVIDIA NIM. For OpenAI: AI_API_BASE=https://api.openai.com/v1  and  AI_MODEL=gpt-4o-mini
# AI_API_BASE=https://integrate.api.nvidia.com/v1
# AI_MODEL=meta/llama-3.1-8b-instruct
# Legacy aliases still work: NVIDIA_API_KEY, NVIDIA_MODEL, NVIDIA_API_BASE
